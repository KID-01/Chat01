  <property name="styleSheet">
   <string notr="true">
/* 整体背景使用杏米色 */
QWidget#LoginWindow {
    background-color: #F5EAD6;
    font-family: "Microsoft YaHei UI";
}

/* 登录卡片 */
QFrame#card {
    background: #ffffff;
    border-radius: 15px;
}

/* 输入框样式 */
QLineEdit {
    border: 1.5px solid #d8cfc0;
    border-radius: 8px;
    padding: 8px 12px;
    background: #ffffff;
    color: #206F50; /* 文字使用深绿 */
    font-size: 13px;
}

QLineEdit:focus {
    border: 1.5px solid #E49D69; /* 聚焦时变为焦糖橙 */
}

/* 登录按钮使用深林绿 */
QPushButton#loginButton {
    background-color: #206F50;
    color: #F5EAD6; /* 文字使用杏米色平衡 */
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: bold;
}

QPushButton#loginButton:hover {
    background-color: #2a8a65;
}

QPushButton#loginButton:pressed {
    background-color: #1a5a41;
}

/* 复选框勾选颜色 */
QCheckBox { color: #5d574d; font-size: 12px; }
QCheckBox::indicator:checked {
    background-color: #E49D69;
    border-radius: 2px;
}

/* 状态标签 */
QLabel#statusLabel { color: #E49D69; font-size: 11px; font-weight: bold; }
   </string>
  </property>

